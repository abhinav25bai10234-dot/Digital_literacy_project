<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Digital Literacy Infographic</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@700;800;900&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: #b8c4dc;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 28px 20px;
    font-family: 'Nunito', sans-serif;
  }

  .poster {
    width: 540px;
    background: #eef2fc;
    position: relative;
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(13,37,84,0.28), 0 6px 20px rgba(0,0,0,0.12);
  }

  /* ===== HEADER ===== */
  .header {
    background: linear-gradient(148deg, #091e4a 0%, #163a7a 42%, #1d56ae 80%, #2268cc 100%);
    padding: 36px 30px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .dot-grid {
    position:absolute; inset:0; pointer-events:none;
    background-image: radial-gradient(circle, rgba(255,255,255,0.13) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .glow {
    position:absolute; width:260px; height:260px; border-radius:50%;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 68%);
    top:50%; left:50%; transform:translate(-50%,-62%); pointer-events:none;
  }
  .header::after {
    content:''; position:absolute;
    bottom:-26px; left:0; right:0; height:52px;
    background:#eef2fc;
    clip-path: ellipse(53% 100% at 50% 100%);
    z-index:2;
  }
  .plus {
    position:absolute; font-family:'Poppins',sans-serif;
    font-weight:900; line-height:1; user-select:none; z-index:1;
  }
  .p1{top:14px;left:18px;font-size:34px;color:rgba(247,201,72,0.65);}
  .p2{top:14px;right:18px;font-size:34px;color:rgba(247,201,72,0.65);}
  .p3{bottom:36px;left:44px;font-size:22px;color:rgba(255,255,255,0.18);}
  .p4{bottom:36px;right:44px;font-size:22px;color:rgba(255,255,255,0.18);}
  .p5{top:46%;left:10px;font-size:16px;color:rgba(255,255,255,0.12);}
  .p6{top:46%;right:10px;font-size:16px;color:rgba(255,255,255,0.12);}

  .header h1 {
    font-family:'Poppins',sans-serif; font-size:34px; font-weight:900;
    color:#fff; line-height:1.1; letter-spacing:1.5px;
    text-transform:uppercase; margin-bottom:15px;
    position:relative; z-index:3;
    text-shadow: 0 3px 16px rgba(0,0,0,0.4);
  }
  .header h1 span { color:#f7c948; }
  .subtitle-banner {
    display:inline-block;
    background:linear-gradient(135deg,#f7c948,#ffe566);
    color:#091e4a; font-size:10.5px; font-weight:800;
    letter-spacing:0.13em; text-transform:uppercase;
    padding:7px 24px; border-radius:24px;
    position:relative; z-index:3;
    box-shadow: 0 4px 18px rgba(247,201,72,0.55), 0 0 0 4px rgba(247,201,72,0.18);
  }

  /* ===== SECTIONS ===== */
  .section {
    display:flex; align-items:center;
    padding:24px 0 18px;
    position:relative; min-height:172px;
  }
  .section.odd  { flex-direction:row; }
  .section.even { flex-direction:row-reverse; }

  .s1 { background:linear-gradient(108deg,#eef2fc,#e5ecfa); }
  .s2 { background:linear-gradient(108deg,#dfe9f6,#d6e4f3); }
  .s3 { background:linear-gradient(108deg,#eef2fc,#e7edfb); }
  .s4 { background:linear-gradient(108deg,#dfe9f6,#d6e4f3); }
  .s5 { background:linear-gradient(108deg,#eef2fc,#e5ecfa); }

  /* coloured side accent bar */
  .section.odd::before {
    content:''; position:absolute; left:0; top:16%; bottom:16%;
    width:5px; border-radius:0 5px 5px 0;
    background:linear-gradient(180deg,#f7c948,#1d56ae);
  }
  .section.even::before {
    content:''; position:absolute; right:0; top:16%; bottom:16%;
    width:5px; border-radius:5px 0 0 5px;
    background:linear-gradient(180deg,#1d56ae,#f7c948);
  }

  .text-block { flex:1; padding:0 20px; position:relative; z-index:2; }

  .num-badge {
    width:42px; height:42px; border-radius:50%;
    background:linear-gradient(135deg,#f7c948,#ffe566);
    color:#091e4a; font-size:21px; font-weight:900;
    font-family:'Poppins',sans-serif;
    display:flex; align-items:center; justify-content:center;
    margin-bottom:10px;
    box-shadow: 0 5px 18px rgba(247,201,72,0.58), 0 0 0 5px rgba(247,201,72,0.13);
  }

  .section-title {
    font-family:'Poppins',sans-serif; font-size:14.5px; font-weight:800;
    color:#091e4a; text-transform:uppercase;
    letter-spacing:0.06em; line-height:1.25; margin-bottom:10px;
  }

  .section-body { font-size:11.5px; color:#253558; line-height:1.74; font-weight:600; }
  .section-body ul { list-style:none; margin-top:4px; }
  .section-body ul li { padding-left:16px; position:relative; margin-bottom:4px; }
  .section-body ul li::before {
    content:'▸'; position:absolute; left:1px;
    color:#f7c948; font-size:11px; line-height:1.62;
  }
  .section-body b { color:#163a7a; }

  .illus {
    width:166px; min-width:166px; height:162px;
    display:flex; align-items:center; justify-content:center;
  }

  /* ===== CURVED SEPARATORS ===== */
  .curved-sep { height:28px; overflow:hidden; line-height:0; }
  .curved-sep svg { display:block; }

  /* ===== FOOTER ===== */
  .footer {
    background:linear-gradient(135deg,#091e4a 0%,#163a7a 100%);
    padding:16px 22px 18px; text-align:center; position:relative; overflow:hidden;
  }
  .footer::before {
    content:''; position:absolute; inset:0;
    background:repeating-linear-gradient(-45deg,transparent,transparent 18px,rgba(255,255,255,0.025) 18px,rgba(255,255,255,0.025) 36px);
  }
  .footer::after {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background:linear-gradient(90deg,transparent,#f7c948,transparent);
  }
  .footer p {
    font-size:10.5px; color:#f7c948; font-weight:800;
    letter-spacing:0.09em; text-transform:uppercase;
    position:relative; z-index:1;
  }
  .footer-divider {
    width:70px; height:2px; margin:7px auto 6px;
    background:linear-gradient(90deg,transparent,rgba(247,201,72,0.6),transparent);
    position:relative; z-index:1;
  }
  .footer .name {
    color:rgba(255,255,255,0.82); font-size:10.5px;
    margin-top:0; letter-spacing:0.05em; font-weight:600;
    position:relative; z-index:1;
  }
</style>
</head>
<body>
<div class="poster">

  <!-- HEADER -->
  <div class="header">
    <div class="dot-grid"></div>
    <div class="glow"></div>
    <span class="plus p1">+</span>
    <span class="plus p2">+</span>
    <span class="plus p3">+</span>
    <span class="plus p4">+</span>
    <span class="plus p5">+</span>
    <span class="plus p6">+</span>
    <h1>Digital<br><span>Literacy</span><br>for Students</h1>
    <div class="subtitle-banner">Know it · Practice it · Stay Safe Online</div>
  </div>

  <!-- ══════════════════════════════════ -->
  <!-- SECTION 1 — What is Dig Literacy  -->
  <!-- ══════════════════════════════════ -->
  <div class="section odd s1">
    <div class="text-block">
      <div class="num-badge">1</div>
      <div class="section-title">What is<br>Digital Literacy?</div>
      <div class="section-body">
        Digital literacy is the ability to find, evaluate, create and communicate using digital tools — safely and responsibly.
        <ul>
          <li>Find &amp; evaluate information online</li>
          <li>Create digital content responsibly</li>
          <li>Communicate effectively online</li>
          <li>Protect your data &amp; identity</li>
        </ul>
      </div>
    </div>
    <div class="illus">
      <svg width="150" height="158" viewBox="0 0 150 158" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="72" cy="118" rx="54" ry="6" fill="rgba(13,37,84,0.1)"/>
        <rect x="22" y="100" width="100" height="15" rx="3.5" fill="#163a7a"/>
        <rect x="32" y="106" width="80" height="4" rx="2" fill="#091e4a" opacity="0.35"/>
        <rect x="26" y="47" width="92" height="56" rx="6" fill="#163a7a"/>
        <rect x="30" y="51" width="84" height="48" rx="4" fill="#2268cc"/>
        <rect x="30" y="51" width="84" height="13" rx="4" fill="rgba(255,255,255,0.11)"/>
        <rect x="36" y="66" width="46" height="4.5" rx="2.2" fill="white" opacity="0.9"/>
        <rect x="36" y="74" width="62" height="2.8" rx="1.4" fill="white" opacity="0.5"/>
        <rect x="36" y="80" width="55" height="2.8" rx="1.4" fill="white" opacity="0.45"/>
        <rect x="36" y="86" width="58" height="2.8" rx="1.4" fill="white" opacity="0.4"/>
        <rect x="90" y="57" width="20" height="20" rx="5" fill="#f7c948"/>
        <rect x="93" y="62" width="12" height="3" rx="1.2" fill="#091e4a"/>
        <rect x="93" y="68" width="8" height="2.5" rx="1" fill="#091e4a" opacity="0.55"/>
        <rect x="62" y="101" width="24" height="4" rx="2" fill="#091e4a"/>
        <!-- person -->
        <path d="M52 42 Q52 28 74 27 Q96 28 96 42 L93 72 L55 72 Z" fill="#2268cc"/>
        <circle cx="74" cy="21" r="14" fill="#f5c5a3"/>
        <path d="M60 15 Q74 7 88 15 Q89 8 74 7 Q59 8 60 15Z" fill="#2c1a0e"/>
        <circle cx="69" cy="21" r="1.7" fill="#2c1a0e"/>
        <circle cx="79" cy="21" r="1.7" fill="#2c1a0e"/>
        <circle cx="70" cy="20" r="0.65" fill="white"/>
        <circle cx="80" cy="20" r="0.65" fill="white"/>
        <path d="M69 27 Q74 31 79 27" stroke="#c07850" stroke-width="1.4" fill="none" stroke-linecap="round"/>
        <path d="M55 47 Q43 60 39 96" stroke="#2268cc" stroke-width="10" stroke-linecap="round" fill="none"/>
        <path d="M93 47 Q105 60 109 96" stroke="#2268cc" stroke-width="10" stroke-linecap="round" fill="none"/>
        <circle cx="39" cy="98" r="6.5" fill="#f5c5a3"/>
        <circle cx="109" cy="98" r="6.5" fill="#f5c5a3"/>
        <text x="118" y="32" font-size="16" fill="#f7c948">✦</text>
        <text x="8" y="54" font-size="12" fill="#f7c948" opacity="0.7">✦</text>
        <text x="120" y="70" font-size="9" fill="#f7c948" opacity="0.5">✦</text>
      </svg>
    </div>
  </div>

  <div class="curved-sep">
    <svg viewBox="0 0 540 28" preserveAspectRatio="none"><path d="M0,0 C135,28 405,28 540,0 L540,0 L0,0 Z" fill="#eef2fc"/></svg>
  </div>

  <!-- ══════════════════════════════════ -->
  <!-- SECTION 2 — Safe Internet         -->
  <!-- ══════════════════════════════════ -->
  <div class="section even s2">
    <div class="text-block">
      <div class="num-badge">2</div>
      <div class="section-title">Safe Internet<br>Practices</div>
      <div class="section-body">
        <ul>
          <li>Use strong passwords (letters + numbers + symbols)</li>
          <li>Enable two-factor authentication (2FA)</li>
          <li>Never click suspicious links — spot phishing</li>
          <li>Avoid banking on public Wi-Fi networks</li>
          <li>Review privacy settings on all platforms</li>
        </ul>
      </div>
    </div>
    <div class="illus">
      <svg width="150" height="158" viewBox="0 0 150 158" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="72" cy="80" rx="50" ry="56" fill="rgba(34,104,204,0.07)"/>
        <path d="M72 12 L116 34 L116 78 Q116 112 72 132 Q28 112 28 78 L28 34 Z" fill="#163a7a"/>
        <path d="M72 20 L108 40 L108 78 Q108 106 72 122 Q36 106 36 78 L36 40 Z" fill="#2268cc"/>
        <path d="M72 20 L108 40 L108 54 Q90 45 72 45 Q54 45 36 54 L36 40 Z" fill="rgba(255,255,255,0.11)"/>
        <rect x="57" y="74" width="30" height="26" rx="5.5" fill="white"/>
        <path d="M63 74 L63 64 Q63 54 72 54 Q81 54 81 64 L81 74" stroke="white" stroke-width="5" fill="none" stroke-linecap="round"/>
        <circle cx="72" cy="83" r="5" fill="#163a7a"/>
        <rect x="70" y="83" width="4" height="8" rx="2" fill="#163a7a"/>
        <!-- check badge -->
        <circle cx="112" cy="120" r="20" fill="#f7c948"/>
        <circle cx="112" cy="120" r="15" fill="#ffe566"/>
        <path d="M102 120 L108 127 L122 111" stroke="#091e4a" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <!-- floating badge -->
        <rect x="10" y="36" width="18" height="18" rx="5" fill="#f7c948" opacity="0.85"/>
        <circle cx="15" cy="45" r="2.2" fill="#091e4a"/>
        <circle cx="20" cy="45" r="2.2" fill="#091e4a"/>
        <circle cx="25" cy="45" r="2.2" fill="#091e4a"/>
        <!-- wifi -->
        <path d="M18 116 Q28 106 38 116" stroke="#2268cc" stroke-width="3.2" fill="none" stroke-linecap="round"/>
        <path d="M12 109 Q28 96 44 109" stroke="#2268cc" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.4"/>
        <circle cx="28" cy="121" r="3.5" fill="#2268cc"/>
      </svg>
    </div>
  </div>

  <div class="curved-sep">
    <svg viewBox="0 0 540 28" preserveAspectRatio="none"><path d="M0,28 C135,0 405,0 540,28 L540,28 L0,28 Z" fill="#dfe9f6"/></svg>
  </div>

  <!-- ══════════════════════════════════ -->
  <!-- SECTION 3 — Digital Tools         -->
  <!-- ══════════════════════════════════ -->
  <div class="section odd s3">
    <div class="text-block">
      <div class="num-badge">3</div>
      <div class="section-title">Useful Digital<br>Tools for Students</div>
      <div class="section-body">
        <ul>
          <li><b>Learning:</b> GeeksforGeeks, Coursera, HackerRank</li>
          <li><b>Collaboration:</b> Google Docs, Google Meet, Canva</li>
          <li><b>Building:</b> GitHub, VS Code, Kaggle</li>
          <li><b>Productivity:</b> Notion, Google Calendar</li>
        </ul>
      </div>
    </div>
    <div class="illus">
      <svg width="150" height="158" viewBox="0 0 150 158" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="70" cy="120" rx="42" ry="6" fill="rgba(13,37,84,0.1)"/>
        <rect x="16" y="26" width="100" height="76" rx="8" fill="#163a7a"/>
        <rect x="20" y="30" width="92" height="68" rx="5" fill="#2268cc"/>
        <rect x="20" y="30" width="92" height="16" rx="5" fill="rgba(255,255,255,0.1)"/>
        <!-- app tiles -->
        <rect x="26" y="40" width="24" height="20" rx="5" fill="#f7c948"/>
        <rect x="54" y="40" width="24" height="20" rx="5" fill="white" opacity="0.88"/>
        <rect x="82" y="40" width="24" height="20" rx="5" fill="#34c98a"/>
        <rect x="26" y="64" width="24" height="20" rx="5" fill="white" opacity="0.88"/>
        <rect x="54" y="64" width="24" height="20" rx="5" fill="#f7c948" opacity="0.72"/>
        <rect x="82" y="64" width="24" height="20" rx="5" fill="white" opacity="0.88"/>
        <!-- tile icons text -->
        <text x="29" y="55" font-size="11" fill="#091e4a">✎</text>
        <text x="57" y="55" font-size="11" fill="#163a7a">⚙</text>
        <text x="85" y="55" font-size="11" fill="white">✓</text>
        <!-- stand -->
        <rect x="62" y="102" width="18" height="12" rx="0" fill="#091e4a"/>
        <rect x="46" y="113" width="50" height="8" rx="4" fill="#091e4a"/>
        <!-- person -->
        <circle cx="126" cy="58" r="12" fill="#f5c5a3"/>
        <ellipse cx="126" cy="80" rx="11" ry="12" fill="#f7c948"/>
        <path d="M114 54 Q126 47 138 54 Q136 46 126 45 Q116 46 114 54Z" fill="#2c1a0e"/>
        <circle cx="122" cy="58" r="1.5" fill="#2c1a0e"/>
        <circle cx="130" cy="58" r="1.5" fill="#2c1a0e"/>
        <path d="M114 74 Q106 68 98 60" stroke="#f5c5a3" stroke-width="6.5" stroke-linecap="round" fill="none"/>
        <text x="4" y="33" font-size="18" fill="#f7c948">★</text>
        <text x="4" y="112" font-size="13" fill="#2268cc" opacity="0.5">★</text>
        <text x="120" y="134" font-size="11" fill="#f7c948" opacity="0.6">✦</text>
      </svg>
    </div>
  </div>

  <div class="curved-sep">
    <svg viewBox="0 0 540 28" preserveAspectRatio="none"><path d="M0,0 C135,28 405,28 540,0 L540,0 L0,0 Z" fill="#eef2fc"/></svg>
  </div>

  <!-- ══════════════════════════════════ -->
  <!-- SECTION 4 — Professional Presence  -->
  <!-- ══════════════════════════════════ -->
  <div class="section even s4">
    <div class="text-block">
      <div class="num-badge">4</div>
      <div class="section-title">Professional<br>Online Presence</div>
      <div class="section-body">
        <ul>
          <li>Set up LinkedIn with your education &amp; skills</li>
          <li>Create a GitHub profile with a README</li>
          <li>Keep a consistent username everywhere</li>
          <li>Think before posting — your digital footprint is permanent</li>
        </ul>
      </div>
    </div>
    <div class="illus">
      <svg width="150" height="158" viewBox="0 0 150 158" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- card shadow -->
        <rect x="26" y="34" width="94" height="106" rx="12" fill="rgba(13,37,84,0.12)"/>
        <!-- card body -->
        <rect x="22" y="28" width="94" height="106" rx="11" fill="white" stroke="#d8e2f0" stroke-width="1.5"/>
        <!-- card header -->
        <rect x="22" y="28" width="94" height="42" rx="11" fill="#163a7a"/>
        <rect x="22" y="55" width="94" height="15" rx="0" fill="#163a7a"/>
        <!-- subtle wave on header -->
        <path d="M22 60 Q36 56 50 60 Q64 64 78 60 Q92 56 116 60 L116 55 L22 55Z" fill="rgba(255,255,255,0.07)"/>
        <!-- avatar -->
        <circle cx="69" cy="70" r="22" fill="white" stroke="#d8e2f0" stroke-width="2"/>
        <circle cx="69" cy="63" r="11" fill="#f5c5a3"/>
        <ellipse cx="69" cy="79" rx="14" ry="10" fill="#2268cc"/>
        <path d="M58 59 Q69 52 80 59 Q78 51 69 50 Q60 51 58 59Z" fill="#2c1a0e"/>
        <!-- name bar -->
        <rect x="36" y="96" width="66" height="7" rx="3.5" fill="#163a7a" opacity="0.6"/>
        <!-- info lines -->
        <rect x="42" y="108" width="54" height="3.5" rx="1.75" fill="#2268cc" opacity="0.4"/>
        <rect x="46" y="116" width="46" height="3.5" rx="1.75" fill="#2268cc" opacity="0.28"/>
        <!-- platform badges -->
        <rect x="28" y="122" width="26" height="12" rx="4" fill="#0077b5"/>
        <text x="32" y="132" font-size="8" fill="white" font-weight="700" font-family="Arial">in</text>
        <rect x="58" y="122" width="26" height="12" rx="4" fill="#24292e"/>
        <text x="62.5" y="132" font-size="7.5" fill="white" font-weight="700" font-family="Arial">gh</text>
        <rect x="88" y="122" width="26" height="12" rx="4" fill="#f7c948"/>
        <text x="92" y="132" font-size="7" fill="#091e4a" font-weight="700" font-family="Arial">kg</text>
        <!-- verified badge -->
        <circle cx="114" cy="40" r="16" fill="#f7c948"/>
        <circle cx="114" cy="40" r="12" fill="#ffe566"/>
        <path d="M105 40 L111 47 L123 33" stroke="#091e4a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>
  </div>

  <div class="curved-sep">
    <svg viewBox="0 0 540 28" preserveAspectRatio="none"><path d="M0,28 C135,0 405,0 540,28 L540,28 L0,28 Z" fill="#dfe9f6"/></svg>
  </div>

  <!-- ══════════════════════════════════ -->
  <!-- SECTION 5 — Email Etiquette       -->
  <!-- ══════════════════════════════════ -->
  <div class="section odd s5" style="padding-bottom:26px;">
    <div class="text-block">
      <div class="num-badge">5</div>
      <div class="section-title">Email<br>Etiquette</div>
      <div class="section-body">
        <ul>
          <li>Write a clear, specific subject line</li>
          <li>Start: "Dear Professor / Dear Sir"</li>
          <li>Structure: Purpose → Details → Request</li>
          <li>Sign off with full name &amp; reg. number</li>
          <li>No slang, no all-caps — always proofread</li>
        </ul>
      </div>
    </div>
    <div class="illus">
      <svg width="150" height="158" viewBox="0 0 150 158" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- shadow -->
        <rect x="12" y="50" width="106" height="78" rx="9" fill="rgba(13,37,84,0.1)"/>
        <!-- envelope back -->
        <rect x="8" y="44" width="106" height="76" rx="8" fill="#163a7a"/>
        <!-- interior -->
        <rect x="12" y="48" width="98" height="68" rx="6" fill="#eef2fc"/>
        <!-- letter lines -->
        <rect x="20" y="60" width="58" height="5" rx="2.5" fill="#163a7a" opacity="0.5"/>
        <rect x="20" y="70" width="78" height="3.2" rx="1.6" fill="#2268cc" opacity="0.38"/>
        <rect x="20" y="77" width="70" height="3.2" rx="1.6" fill="#2268cc" opacity="0.33"/>
